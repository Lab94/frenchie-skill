{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.lab94/frenchie-skill",
  "title": "Frenchie",
  "description": "OCR, transcription, and image generation for AI agents via MCP.",
  "repository": {
    "url": "https://github.com/Lab94/frenchie-skill",
    "source": "github"
  },
  "version": "0.4.1",
  "websiteUrl": "https://getfrenchie.dev",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@lab94/frenchie",
      "version": "0.4.1",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        },
        {
          "type": "positional",
          "value": "@lab94/frenchie@0.4.1"
        },
        {
          "type": "positional",
          "value": "mcp"
        }
      ],
      "environmentVariables": [
        {
          "name": "FRENCHIE_API_KEY",
          "description": "Your Frenchie API key (starts with fr_). Create one at https://getfrenchie.dev/dashboard/api-keys — first signup comes with 100 free credits.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.getfrenchie.dev",
      "headers": [
        {
          "name": "Authorization",
          "description": "Bearer fr_... — your Frenchie API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
